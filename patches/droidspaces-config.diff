diff --git a/arch/arm64/configs/lineageos_joan_defconfig b/arch/arm64/configs/lineageos_joan_defconfig
index d27aa691..e3fb8542 100644
--- a/arch/arm64/configs/lineageos_joan_defconfig
+++ b/arch/arm64/configs/lineageos_joan_defconfig
@@ -732,3 +732,87 @@ CONFIG_KSU_MANUAL_HOOK=y
 # CONFIG_KSU_KPROBES_HOOK is not set
 CONFIG_KPROBES=y
 CONFIG_KPROBE_EVENTS=y
+
+# DroidSpaces - IPC mechanisms
+CONFIG_SYSVIPC=y
+CONFIG_POSIX_MQUEUE=y
+
+# DroidSpaces - Namespaces (required for container isolation)
+CONFIG_PID_NS=y
+CONFIG_UTS_NS=y
+CONFIG_IPC_NS=y
+CONFIG_NET_NS=y
+
+# DroidSpaces - Seccomp filter
+CONFIG_SECCOMP_FILTER=y
+
+# DroidSpaces - Control groups (device, pids, memory, scheduler)
+CONFIG_CGROUPS=y
+CONFIG_CGROUP_DEVICE=y
+CONFIG_CGROUP_PIDS=y
+CONFIG_MEMCG=y
+CONFIG_CGROUP_SCHED=y
+CONFIG_FAIR_GROUP_SCHED=y
+CONFIG_CGROUP_NET_PRIO=y
+
+# DroidSpaces - Device filesystem
+CONFIG_DEVTMPFS=y
+
+# DroidSpaces - tmpfs extended attributes (NixOS support)
+CONFIG_TMPFS_XATTR=y
+
+# DroidSpaces - Firmware loader
+CONFIG_FW_LOADER=y
+CONFIG_FW_LOADER_USER_HELPER=y
+CONFIG_FW_LOADER_COMPRESS=y
+
+# DroidSpaces - Network: veth pair, bridge netfilter, nftables
+CONFIG_VETH=y
+CONFIG_BRIDGE_NETFILTER=y
+CONFIG_NETFILTER_ADVANCED=y
+CONFIG_NF_NAT=y
+CONFIG_NF_TABLES=y
+CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
+CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
+CONFIG_NF_CONNTRACK_NETLINK=y
+CONFIG_NF_NAT_REDIRECT=y
+CONFIG_NF_CONNTRACK_IPV4=y
+CONFIG_NF_NAT_IPV4=y
+CONFIG_IP_NF_NAT=y
+
+# DroidSpaces - Disable paranoid network (fix internet in containers)
+# CONFIG_ANDROID_PARANOID_NETWORK is not set
+
+# DroidSpaces - User namespaces (fix docker unsafe procfs)
+CONFIG_USER_NS=y